; Tests that getstatic with explicit @utf8 type hint stores operand as Utf8 instead of Fieldref.
; Expected: success, javap shows Utf8 entry for getstatic operand

.class public MyClass
.super java/lang/Object

.method public static main ()V
    .code stack 1 locals 1
      getstatic @utf8 some_value
      return
    .code_end
.method_end
.class_end
